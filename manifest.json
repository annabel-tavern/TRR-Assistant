{
  "manifest_version": 3,
  "name": "RealReal Enhancer",
  "version": "2.0.0",
  "description": "Shop The RealReal faster with filter presets, item labels, price tracking, a side panel, and a full dashboard",
  "permissions": ["storage", "activeTab", "sidePanel"],
  "host_permissions": ["https://www.therealreal.com/*"],
  "content_scripts": [
    {
      "matches": ["https://www.therealreal.com/*"],
      "js": ["content.js", "content-labels.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  }
}
